# ============================================================
#  雪年个人网站 - 环境变量配置
#  复制此文件为 .env 并填入实际值
#  Nuxt runtimeConfig 会自动映射 NUXT_ 前缀的变量
# ============================================================

# ---------- AI 默认配置（OpenAI 兼容格式）----------
# 支持 OpenAI、Azure OpenAI、Ollama 等兼容 API
NUXT_AI_API_KEY=your-api-key-here
NUXT_AI_API_BASE_URL=https://api.openai.com/v1
NUXT_AI_MODEL=gpt-3.5-turbo

# 示例：使用本地 Ollama
# NUXT_AI_API_KEY=ollama
# NUXT_AI_API_BASE_URL=http://localhost:11434/v1
# NUXT_AI_MODEL=qwen2.5:7b

# ---------- AI 聊天预设（可选，JSON 数组格式）----------
# 每个预设可配置不同的 API 地址、密钥、模型和 system prompt
# systemPrompt 可选，不填则使用默认的「雪年」角色提示词
# 客户端可通过 /api/presets 获取预设名称列表
# NUXT_AI_PRESETS='[{"name":"GPT-4","apiKey":"sk-xxx","baseUrl":"https://api.openai.com/v1","model":"gpt-4","systemPrompt":"你是一个专业的编程助手，请用简洁清晰的中文回答"},{"name":"本地Ollama","apiKey":"ollama","baseUrl":"http://localhost:11434/v1","model":"qwen2.5:7b"}]'

# 公开的预设名称列表（仅暴露名称，不包含密钥，可选）
# NUXT_PUBLIC_AI_PRESET_NAMES='["GPT-4","本地Ollama"]'

# ---------- 管理后台 ----------
# 登录管理后台 /admin 的密码（默认 admin123，生产环境务必修改）
NUXT_ADMIN_PASSWORD=your-admin-password-here
